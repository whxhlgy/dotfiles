{
    "suggest.noselect":true,
    "languageserver": {
      "digestif": {
        "command": "digestif",
        "filetypes": ["tex", "plaintex", "context"]
      }
    },

    "html.autoClosingTags": true,
    "html.autoCreateQuotes": true,
    "clangd.fallbackFlags": ["-std=c++17"],
    "jedi.enable": false
}
